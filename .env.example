# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Required — use `softauth secret` to generate a strong key
SOFTAUTH_SECRET=change-me-use-softauth-secret-to-generate

# Database URL (SQLAlchemy format)
# SQLite (default, good for development)
SOFTAUTH_DB_URL=sqlite:///auth.db

# PostgreSQL example
# SOFTAUTH_DB_URL=postgresql://user:password@localhost:5432/mydb

# MySQL example
# SOFTAUTH_DB_URL=mysql+pymysql://user:password@localhost:3306/mydb

# JWT algorithm (HS256 is the default, RS256 is supported by PyJWT)
SOFTAUTH_ALGORITHM=HS256
